{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/uploads/:path*", "destination": "/uploads/:path*" },
    { "source": "/style.css", "destination": "/style.css" },
    { "source": "/Login.html", "destination": "/Login.html" },
    { "source": "/Register.html", "destination": "/Register.html" },
    { "source": "/VendorLogin.html", "destination": "/VendorLogin.html" },
    { "source": "/VendorRegister.html", "destination": "/VendorRegister.html" },
    { "source": "/:name.php", "destination": "/api/:name.php" },
    { "source": "/", "destination": "/api/Homepage.php" }
  ]
}
